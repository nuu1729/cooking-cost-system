# Flask環境設定 (development / staging / production)
FLASK_ENV=development
PORT=3001

# データベース接続URL
# 開発: mysql+pymysql://<user>:<password>@localhost:3306/<dbname>
# 本番: 環境変数 DATABASE_URL_PRODUCTION を使用
DATABASE_URL=mysql+pymysql://cooking_user:cooking_password@localhost:3306/cooking_cost_system
DATABASE_URL_PRODUCTION=mysql+pymysql://<user>:<password>@<host>:3306/<dbname>

# セキュリティキー（本番では必ず64文字以上のランダム文字列を設定）
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-replace-with-random-64chars
SECRET_KEY=your-secret-key-replace-with-random-64chars
