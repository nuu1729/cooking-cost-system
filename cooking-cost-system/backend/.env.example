# =============================================================
# 料理原価計算システム 環境変数設定ファイル
# =============================================================
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
#
# staging / production の secrets は scripts/generate-env.sh で
# Cloudflare Wrangler secrets として設定してください（このファイルには書き込まない）。
#   bash scripts/generate-env.sh --env staging
#   bash scripts/generate-env.sh --env production
# =============================================================

# ── アプリケーション環境 ─────────────────────────────────────
# development / staging / production
# （Flask 3.0 で廃止された FLASK_ENV の代替として APP_ENV を使用）
APP_ENV=development
PORT=3001

# ── データベース ──────────────────────────────────────────────
# 開発環境（MySQL をローカルで起動している場合。docker-compose.yml の database サービス）
DATABASE_URL=mysql+pymysql://cooking_user:cooking_password@localhost:3306/cooking_cost_system

# staging / production（APP_ENV=staging または production のときのみ参照）
# バックエンドは Cloudflare D1 に接続する（wrangler d1 create で作成した DB を使用）
# ⚠️  実際のトークンをこのファイルに記入しないこと。CF_D1_API_TOKEN は
#     Cloudflare Containers では wrangler secret put で設定する（Docker secrets を使う
#     デプロイでは {SECRETS_DIR}/cf_d1_api_token ファイルでも可）。
CF_ACCOUNT_ID=<Cloudflareアカウントの Account ID>
CF_D1_DATABASE_ID=<wrangler d1 create の出力に含まれる database_id>
CF_D1_API_TOKEN=<D1:Edit 権限を持つ Cloudflare API トークン>

# ── アップロードファイル保存（Cloudflare R2） ───────────────────
# アイコン・背景画像は R2（S3 互換）に保存する（wrangler r2 bucket create で作成したバケット）
# ⚠️  実際のキーをこのファイルに記入しないこと。R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY は
#     dash.cloudflare.com の R2 → Manage R2 API Tokens で発行し、
#     Cloudflare Containers では wrangler secret put で設定する。
R2_BUCKET_NAME=<wrangler r2 bucket create で作成したバケット名>
R2_ACCESS_KEY_ID=<R2 API トークンの Access Key ID>
R2_SECRET_ACCESS_KEY=<R2 API トークンの Secret Access Key>

# ── セキュリティキー ──────────────────────────────────────────
# 本番では必ず下記コマンドで生成したランダム文字列を設定すること
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  デフォルト値のまま本番運用しないこと
JWT_SECRET=your-jwt-secret-replace-with-random-string
SECRET_KEY=your-secret-key-replace-with-random-string

# ── CORS ──────────────────────────────────────────────────────
# カンマ区切りで複数オリジンを指定可能
# 本番環境では https:// のオリジンのみ許可（localhost は起動エラーになります）

# 開発環境
CORS_ORIGIN=http://localhost:3000

# 本番環境例（Cloudflare Pages のドメインを指定）
# CORS_ORIGIN=https://your-project.pages.dev
# CORS_ORIGIN=https://your-project.pages.dev,https://yourdomain.com
