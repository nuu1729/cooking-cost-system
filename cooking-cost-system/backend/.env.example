# =============================================================
# 料理原価計算システム 環境変数設定ファイル
# =============================================================
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
#
# 本番環境の場合は scripts/generate-env.sh を使用してください。
#   bash scripts/generate-env.sh
# =============================================================

# ── Flask 環境 ────────────────────────────────────────────────
# development / staging / production
FLASK_ENV=development
PORT=3001

# ── データベース ──────────────────────────────────────────────
# 開発環境（MySQL をローカルで起動している場合）
DATABASE_URL=mysql+pymysql://cooking_user:cooking_password@localhost:3306/cooking_cost_system

# 本番環境（FLASK_ENV=production のときのみ参照）
# ⚠️  実際のパスワードをこのファイルに記入しないこと。
#     .env.production は .gitignore で除外済み。scripts/generate-env.sh で自動生成推奨。
# Docker Compose 内では DB コンテナのサービス名（database）をホスト名に指定する
DATABASE_URL_PRODUCTION=mysql+pymysql://<user>:<password>@database:3306/cooking_cost_system

# ── セキュリティキー ──────────────────────────────────────────
# 本番では必ず下記コマンドで生成したランダム文字列を設定すること
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  デフォルト値のまま本番運用しないこと
JWT_SECRET=your-jwt-secret-replace-with-random-string
SECRET_KEY=your-secret-key-replace-with-random-string

# ── CORS ──────────────────────────────────────────────────────
# カンマ区切りで複数オリジンを指定可能
# 本番環境では https:// のオリジンのみ許可（localhost は起動エラーになります）

# 開発環境
CORS_ORIGIN=http://localhost:3000

# 本番環境例（Cloudflare Pages のドメインを指定）
# CORS_ORIGIN=https://your-project.pages.dev
# CORS_ORIGIN=https://your-project.pages.dev,https://yourdomain.com
